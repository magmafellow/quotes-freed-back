generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// model User {
//   id    Int     @id @default(autoincrement())
//   email String  @unique
//   name  String?
//   posts Post[]
// }
model User {
  id                     Int                  @id @default(autoincrement())
  email                  String               @unique
  password               String
  username               String               @unique
  firstName              String               @map("first_name")
  lastName               String               @map("last_name")
  dateCreated            DateTime             @default(now()) @map("date_created")
  dateUpdated            DateTime             @default(now()) @updatedAt @map("date_updated")
       
  quotes                 Quote[]
  likes_usersQuotes      Likes_UsersQuotes[]
}


model Author {
  id                     Int                  @id
  firstName              String?              @map("first_name")
  lastName               String?              @map("last_name")
  dateBorn               DateTime?            @map("date_born")

  quotes                 Quote[]
}


model Quote {
  id                     Int                  @id @default(autoincrement())
  content                String      
  author                 Author?              @relation(fields: [authorId], references: [id])
  authorId               Int?                 @map("author_id")
  dateCreatedOrigin      DateTime             @map("date_created_origin")
  dateCreated            DateTime             @default(now()) @map("date_created")

// Quote can be made by an user (so be an author). Also be made by the user but with specifed author (add mod)
  user                   User?                @relation(fields: [userId], references: [id])
  userId                 Int?                 @map("user_id")

  likes_usersQuotes      Likes_UsersQuotes[]
}

model Likes_UsersQuotes {
  id                     Int                  @id @default(autoincrement())
  user                   User                 @relation(fields: [userId], references: [id])
  userId                 Int                  @map("user_id")
  quote                  Quote                @relation(fields: [quoteId], references: [id])
  quoteId                Int                  @map("quote_id")

  dateCreated            DateTime             @default(now()) @map("date_created")
}
